          }}
        >
          <button
            onClick={() => setActiveTab('Cobranzas')}
            style={{
              ...tabBtn,
              background: activeTab === 'Cobranzas' ? '#0f172a' : '#f3f4f6',
              color: activeTab === 'Cobranzas' ? '#fff' : '#374151',
            }}
          >
            Cobranzas
          </button>
          <button
            onClick={() => setActiveTab('Jurídico')}
            style={{
              ...tabBtn,
