                        <td style={tdStyle}>{row.seguimiento.operator || '—'}</td>
                        <td style={tdStyle}>{row.seguimiento.gestor || '—'}</td>
                      </tr>
                    );
                  })}

                  {!visibleRows.length && (
                    <tr>
                      <td
                        colSpan={16}
